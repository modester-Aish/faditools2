WORDPRESS_BACKEND_URL=
WORDPRESS_SYNC_URL=
WORDPRESS_USERNAME=
WORDPRESS_APPLICATION_PASSWORD=
WOOCOMMERCE_KEY=
WOOCOMMERCE_SECRET=

## Copy to .env.local (DO NOT COMMIT secrets)
## Required for WordPress + WooCommerce live data

WORDPRESS_BASE_URL=https://app.faditools.com
WOOCOMMERCE_BASE_URL=https://app.faditools.com

WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

## Optional (only if you use WP Application Password flows)
WORDPRESS_USERNAME=admin
WORDPRESS_APPLICATION_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

## Optional (only if using on-demand revalidation endpoints)
REVALIDATE_SECRET=your_random_secret_here

